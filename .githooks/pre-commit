#!/usr/bin/env bash
set -euo pipefail

# pre-commit — Repo hygiene guard.
#
# Two checks before any commit lands:
#
#   1. Refuse staged paths inside gitignored zones (do/, docs/, var/, data/,
#      outputs/, dist/). Catches `git add -f` accidents.
#
#   2. Run scripts/hygiene_check.sh --staged on staged files: fails on
#      absolute system paths, data.md references in src/tests/configs,
#      repo-local caches, and git diff --check issues. AI tool name
#      mentions are reported as warnings only.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Bypass (rare, intentional):
#   git commit --no-verify

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

staged="$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)"

if [[ -z "$staged" ]]; then
  exit 0
fi

# --- Rule 1: refuse staged paths under gitignored zones ---
banned_zones='^(do|docs|var|data|outputs|dist)/'
banned_hits="$(printf '%s\n' "$staged" | grep -E "$banned_zones" || true)"

if [[ -n "$banned_hits" ]]; then
  echo "pre-commit: REJECT — the following staged paths live in gitignored zones:" >&2
  printf '  %s\n' $banned_hits >&2
  echo "" >&2
  echo "These directories are private working state and must never be committed:" >&2
  echo "  do/      — agent memory, handoff, todo, changes, plans" >&2
  echo "  docs/    — private design docs" >&2
  echo "  var/     — async job state" >&2
  echo "  data/    — local data" >&2
  echo "  outputs/ — generated artifacts" >&2
  echo "  dist/    — build outputs" >&2
  echo "" >&2
  echo "If something needs to be shared publicly, copy it to a tracked location" >&2
  echo "(README.md, src/, tests/, configs/, scripts/) and recommit." >&2
  exit 1
fi

# --- Rule 2: hygiene_check on staged files only ---
# Fail CLOSED: if the hook is installed (core.hooksPath=.githooks) but its check
# script is missing or non-executable, the hygiene gate cannot run — reject rather
# than silently letting the commit through.
if [[ -x scripts/hygiene_check.sh ]]; then
  if ! scripts/hygiene_check.sh --staged; then
    echo "" >&2
    echo "pre-commit: REJECT — hygiene_check failed on staged files." >&2
    echo "Fix the reported violations, re-stage, and retry." >&2
    echo "(Use 'git commit --no-verify' only when intentionally bypassing.)" >&2
    exit 1
  fi
elif [[ -f scripts/hygiene_check.sh ]]; then
  echo "pre-commit: REJECT — scripts/hygiene_check.sh exists but is not executable; the hygiene gate cannot run." >&2
  echo "Fix: chmod +x scripts/hygiene_check.sh (or 'git commit --no-verify' to bypass intentionally)." >&2
  exit 1
else
  echo "pre-commit: REJECT — scripts/hygiene_check.sh is missing; the hygiene gate cannot run." >&2
  echo "This hook is installed but its check script is absent — restore it from the templates" >&2
  echo "(or 'git commit --no-verify' to bypass intentionally)." >&2
  exit 1
fi

exit 0
