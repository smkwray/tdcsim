{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdcsim.local/schemas/cbo-run-manifest-v1.schema.json",
  "title": "TDCSIM CBO scenario run manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "verification_grade",
    "generated_at_utc",
    "baseline",
    "scenario",
    "code_environment",
    "claim_boundary",
    "coupling_decisions",
    "compiled_manifest",
    "compiled_inputs_digest",
    "compiled_inputs",
    "simulation",
    "outputs",
    "output_manifest",
    "output_hashes",
    "boundary_checks",
    "validation",
    "unsupported_components"
  ],
  "properties": {
    "schema_version": {
      "const": "tdcsim_cbo_scenario_run_manifest_v1"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,159}$"
    },
    "status": {
      "enum": [
        "complete",
        "failed",
        "compiled_only"
      ]
    },
    "verification_grade": {
      "enum": [
        "local",
        "release_reproducible",
        "release_verified"
      ]
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_sha256",
        "manifest_sha256",
        "release_attestation_sha256"
      ],
      "properties": {
        "package_id": {
          "type": "string"
        },
        "package_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "release_attestation_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "canonical_sha256",
        "source_file_sha256",
        "relative_path",
        "referenced_file_hashes"
      ],
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "canonical_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_file_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "relative_path": {
          "type": "string"
        },
        "referenced_file_hashes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "code_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code_commit_sha",
        "dirty_state",
        "requirements_lock_sha256",
        "python_version",
        "runner_version",
        "verifier_version",
        "runner_source_sha256"
      ],
      "properties": {
        "code_commit_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "dirty_state": {
          "type": "boolean"
        },
        "requirements_lock_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "python_version": {
          "type": "string"
        },
        "runner_version": {
          "type": "string"
        },
        "verifier_version": {
          "type": "string"
        },
        "runner_source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "array"
        ]
      }
    },
    "coupling_decisions": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "compiled_inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      },
      "minItems": 1
    },
    "compiled_manifest": {
      "type": "string"
    },
    "compiled_inputs_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "simulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_date",
        "end_date",
        "frequency"
      ],
      "properties": {
        "start_date": {
          "type": "string",
          "format": "date"
        },
        "end_date": {
          "type": "string",
          "format": "date"
        },
        "frequency": {
          "const": "daily"
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "output_manifest": {
      "type": "object"
    },
    "output_hashes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "boundary_checks": {
      "type": "object"
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "gates",
        "invariants"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "fail"
          ]
        },
        "gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/check"
          }
        }
      }
    },
    "unsupported_components": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_name",
        "relative_path",
        "sha256",
        "bytes"
      ],
      "properties": {
        "logical_name": {
          "type": "string",
          "minLength": 1
        },
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "semantic_digest": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "row_count": {
          "type": "integer",
          "minimum": 0
        },
        "media_type": {
          "type": "string"
        },
        "lineage": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "not_applicable"
          ]
        },
        "observed": {
          "type": [
            "number",
            "string",
            "boolean",
            "null"
          ]
        },
        "limit": {
          "type": [
            "number",
            "string",
            "boolean",
            "null"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
