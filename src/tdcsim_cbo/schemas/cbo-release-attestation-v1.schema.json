{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tdcsim.local/schemas/cbo-release-attestation-v1.schema.json",
  "title": "TDCSIM CBO dependency release attestation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "release_commit_sha",
    "dirty_state",
    "package_zip_sha256",
    "baseline_manifest_sha256",
    "verifier_sha256",
    "requirements_lock_sha256",
    "commands",
    "status"
  ],
  "properties": {
    "schema_version": {
      "const": "tdcsim_cbo_release_attestation_v1"
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "release_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "dirty_state": {
      "const": false
    },
    "package_zip_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "baseline_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "verifier_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "requirements_lock_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "python_version": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "argv",
          "exit_code",
          "stdout_sha256"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "argv": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "exit_code": {
            "const": 0
          },
          "stdout_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "status": {
      "const": "pass"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scheme": {
          "enum": [
            "none",
            "sigstore_bundle",
            "detached_signature"
          ]
        },
        "relative_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
